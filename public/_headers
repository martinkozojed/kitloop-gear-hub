# App paths: noindex so GSC does not index app URLs (SEO MVP).
# Marketing paths (/how-it-works, /about, /terms, /privacy) have no entry here = indexable. Root / = onboarding (app).

/onboarding
  X-Robots-Tag: noindex, nofollow
/onboarding/*
  X-Robots-Tag: noindex, nofollow
/login
  X-Robots-Tag: noindex, nofollow
/signup
  X-Robots-Tag: noindex, nofollow
/forgot-password
  X-Robots-Tag: noindex, nofollow
/reset-password
  X-Robots-Tag: noindex, nofollow
/provider
  X-Robots-Tag: noindex, nofollow
/provider/*
  X-Robots-Tag: noindex, nofollow
/admin
  X-Robots-Tag: noindex, nofollow
/admin/*
  X-Robots-Tag: noindex, nofollow
/demo
  X-Robots-Tag: noindex, nofollow
/demo/*
  X-Robots-Tag: noindex, nofollow
/book
  X-Robots-Tag: noindex, nofollow
